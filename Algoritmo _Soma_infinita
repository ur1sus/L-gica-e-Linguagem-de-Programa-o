algoritmo "Soma"
var
  soma: inteiro
  numero1: inteiro
  numero2: inteiro
  resultado: inteiro
  sentinela: inteiro
inicio
sentinela <- 0
enquanto sentinela <> -99 faca 
 escreval ("Digite numero1": )
 leia (numero1) 
 escreva (Digite numero2": )
 leia (numero2)
 resultado <- numero1 + numero2
 escreval (numero1, "+", numero2, "=", resultado)
 escreval ("Deseja continuar executando? [-99 para sair]")
 leia (sentinela)
fimenquanto
escreval ("Saiu do Laço")
fimalgoritmo
